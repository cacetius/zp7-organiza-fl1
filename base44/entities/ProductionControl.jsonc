{
  "name": "ProductionControl",
  "type": "object",
  "properties": {
    "testor_id": {
      "type": "string",
      "description": "ID do testor"
    },
    "testor_nome": {
      "type": "string",
      "description": "Nome do testor"
    },
    "data": {
      "type": "string",
      "format": "date",
      "description": "Data do registro"
    },
    "turno": {
      "type": "string",
      "enum": [
        "primeiro",
        "segundo",
        "terceiro"
      ],
      "description": "Turno de produ\u00e7\u00e3o"
    },
    "hora": {
      "type": "string",
      "description": "Hora do registro (ex: 15:00)"
    },
    "carros_produzidos": {
      "type": "number",
      "description": "Quantidade de carros produzidos na hora"
    }
  },
  "required": [
    "testor_id",
    "testor_nome",
    "data",
    "turno",
    "hora",
    "carros_produzidos"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "lider"
          }
        },
        {
          "user_condition": {
            "role": "monitor"
          }
        },
        {
          "data.turno": "{{user.data.turno}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "lider"
          }
        },
        {
          "user_condition": {
            "role": "monitor"
          }
        },
        {
          "data.turno": "{{user.data.turno}}"
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "lider"
          }
        }
      ]
    }
  }
}