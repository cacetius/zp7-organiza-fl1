{
  "name": "ShiftHandoff",
  "type": "object",
  "properties": {
    "turno_saindo": {
      "type": "string",
      "enum": [
        "primeiro",
        "segundo",
        "terceiro"
      ]
    },
    "turno_entrando": {
      "type": "string",
      "enum": [
        "primeiro",
        "segundo",
        "terceiro"
      ]
    },
    "producao_realizada": {
      "type": "number"
    },
    "producao_planejada": {
      "type": "number"
    },
    "testores_com_problema": {
      "type": "string",
      "description": "Lista de testores com problema"
    },
    "pendencias_abertas": {
      "type": "number"
    },
    "ocorrencias_criticas": {
      "type": "string"
    },
    "acoes_em_andamento": {
      "type": "string"
    },
    "alertas_proximo_turno": {
      "type": "string"
    },
    "recomendacao_ia": {
      "type": "string"
    },
    "observacao": {
      "type": "string"
    },
    "responsavel": {
      "type": "string"
    },
    "data": {
      "type": "string",
      "format": "date"
    }
  },
  "required": [
    "turno_saindo",
    "turno_entrando"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "lider"
          }
        },
        {
          "user_condition": {
            "role": "monitor"
          }
        },
        {
          "data.turno_saindo": "{{user.data.turno}}"
        },
        {
          "data.turno_entrando": "{{user.data.turno}}"
        }
      ]
    },
    "update": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "lider"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "created_by": "{{user.email}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "lider"
          }
        }
      ]
    }
  }
}